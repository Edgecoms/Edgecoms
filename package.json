{
  "name": "edgecoms",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "dotenv": "^17.2.2",
      "zod": "^4.1.13",
      "typescript": "^6",
      "lucide-react": "^0.546.0",
      "next": "^16.2.0",
      "next-themes": "^0.4.6",
      "react": "^19.2.6",
      "react-dom": "^19.2.6",
      "sonner": "^2.0.5",
      "@trpc/server": "^11.16.0",
      "@trpc/client": "^11.16.0",
      "better-auth": "1.6.11",
      "@types/react": "^19.2.15",
      "@types/react-dom": "^19.2.3",
      "tailwindcss": "^4.1.18"
    }
  },
  "type": "module",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "check-types": "turbo check-types",
    "dev:web": "turbo -F web dev",
    "db:push": "turbo -F @edgecoms/db db:push",
    "db:studio": "turbo -F @edgecoms/db db:studio",
    "db:generate": "turbo -F @edgecoms/db db:generate",
    "db:migrate": "turbo -F @edgecoms/db db:migrate",
    "db:start": "turbo -F @edgecoms/db db:start",
    "db:watch": "turbo -F @edgecoms/db db:watch",
    "db:stop": "turbo -F @edgecoms/db db:stop",
    "db:down": "turbo -F @edgecoms/db db:down",
    "check": "ultracite check",
    "fix": "ultracite fix"
  },
  "dependencies": {
    "@edgecoms/env": "workspace:*",
    "dotenv": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.16",
    "@edgecoms/config": "workspace:*",
    "@types/node": "^22.13.14",
    "turbo": "^2.9.16",
    "typescript": "catalog:",
    "ultracite": "7.8.3"
  },
  "packageManager": "bun@1.3.14"
}
