# ── Database ───────────────────────────────────────────────────────────────
# Postgres connection string. Local Docker default shown; on Railway use the
# private networking URL of the Postgres service.
DATABASE_URL="postgresql://postgres:password@localhost:5432/edgecoms"

# ── Better Auth ────────────────────────────────────────────────────────────
# 32+ char secret. Generate: openssl rand -base64 32
BETTER_AUTH_SECRET=""
# Public base URL of the web app (no trailing slash).
BETTER_AUTH_URL="http://localhost:3001"
# Allowed origin for auth/tRPC requests.
CORS_ORIGIN="http://localhost:3001"

# ── Admin bootstrap (used by `bun run db:create-admin`) ────────────────────
ADMIN_EMAIL="admin@edgecoms.com"
ADMIN_PASSWORD=""
ADMIN_NAME="Edge Admin"

# ── Shopify Partner API (billing sync) ─────────────────────────────────────
# Org-level credentials used by the billing-sync worker and the admin
# "Run sync now". Create the token at:
#   Partner Dashboard → Settings → Partner API clients
# The org id is the number in your partners.shopify.com/<org-id>/ dashboard URL.
# Optional everywhere else; required for the sync to do anything.
PARTNER_API_ORGANIZATION_ID=""
PARTNER_API_ACCESS_TOKEN=""
# Partner API version (use a current stable version from the dashboard).
PARTNER_API_VERSION="2026-04"

# Per-app GID overrides. The seed ships PLACEHOLDER GIDs for the 6 Edge apps;
# override each with its real Partner Dashboard GID using PARTNER_API_GID_<SLUG>
# (slug uppercased, hyphens → underscores), then re-run `bun run db:seed`:
# PARTNER_API_GID_EDGE_BUNDLES="gid://partners/App/123456"
# PARTNER_API_GID_EDGE_TIMER="gid://partners/App/123457"
# PARTNER_API_GID_EDGE_REVIEWS="gid://partners/App/123458"
# PARTNER_API_GID_EDGE_CART="gid://partners/App/123459"
# PARTNER_API_GID_EDGE_CURRENCY="gid://partners/App/123460"
# PARTNER_API_GID_EDGE_SUBSCRIPTIONS="gid://partners/App/123461"
